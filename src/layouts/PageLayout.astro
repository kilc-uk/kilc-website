---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ChatWidget from '../components/ChatWidget.astro';
import { getLocaleFromUrl } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  articleMeta?: {
    publishedTime: string;
    author?: string;
    tags?: string[];
    section?: string;
  };
  jsonLd?: object;
}

const locale = getLocaleFromUrl(Astro.url);
const { title, description, ogImage, ogType, articleMeta, jsonLd } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage} ogType={ogType} articleMeta={articleMeta} jsonLd={jsonLd}>
  <Header locale={locale} />
  <main>
    <slot />
  </main>
  <Footer locale={locale} />
  <ChatWidget locale={locale} />
</BaseLayout>
